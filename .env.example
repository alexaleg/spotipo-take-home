SECRET_KEY=change-me-in-production

# MySQL (must match docker-compose)
MYSQL_ROOT_PASSWORD=password
DATABASE_URL=mysql+pymysql://root:password@db:3306/captive_portal

# UniFi Controller
UNIFI_HOST=https://192.168.1.1
UNIFI_API_KEY=your-api-key-here
UNIFI_SITE_ID=default
UNIFI_VERIFY_SSL=false

# Portal behaviour
PORTAL_AUTHORIZED_MINUTES=480

# Set to true to skip the real UniFi API call (useful for testing without a controller)
UNIFI_MOCK=false
